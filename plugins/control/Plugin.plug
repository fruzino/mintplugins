script = plugins/control/Plugin.py
namespace = pg
description = Pygame graphics — create windows, draw shapes, render text, handle events
author      = Fruzio
version     = 1.0.0
dep    = pygame
cmd    = init
cmd    = quit
cmd    = title
cmd    = fill
cmd    = flip
cmd    = rect
cmd    = circle
cmd    = line
cmd    = text
cmd    = image
cmd    = clear
cmd    = delay
cmd    = key
cmd    = event
cmd    = resize
cmd    = save
